{
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/join",
        "destination": "/join.html"
      },
      {
        "source": "/game",
        "destination": "/game.html"
      }
    ]
  }
}
